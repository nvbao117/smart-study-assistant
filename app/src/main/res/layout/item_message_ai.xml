<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingVertical="4dp">

    <!-- AI Avatar -->
    <com.google.android.material.card.MaterialCardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="?attr/colorPrimaryContainer"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="🤖"
            android:textSize="14sp" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Constrain bubble to ~80% width using a wrapper -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="4"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tvContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chat_ai"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.3"
            tools:text="Integration by parts is a technique that comes from the product rule of differentiation. The formula is: ∫u dv = uv - ∫v du" />
    </LinearLayout>

    <!-- Spacer so bubble doesn't stretch full width -->
    <Space
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1" />

</LinearLayout>
