<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginVertical="6dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutline"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="18dp">

        <!-- Color accent bar -->
        <View
            android:id="@+id/viewAccent"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="?attr/colorPrimary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvDeckName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:textAppearance="@style/TextAppearance.SmartStudy.BodyBold"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintEnd_toStartOf="@id/tvDueCount"
            app:layout_constraintStart_toEndOf="@id/viewAccent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Linear Algebra" />

        <TextView
            android:id="@+id/tvCardCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.SmartStudy.Caption"
            app:layout_constraintEnd_toEndOf="@id/tvDeckName"
            app:layout_constraintStart_toStartOf="@id/tvDeckName"
            app:layout_constraintTop_toBottomOf="@id/tvDeckName"
            tools:text="42 cards" />

        <!-- Due badge -->
        <TextView
            android:id="@+id/tvDueCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill"
            android:backgroundTint="@color/accent_success_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textAppearance="@style/TextAppearance.SmartStudy.Caption"
            android:textColor="@color/accent_success"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="5 due" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
